# Copy this file to `.env.local` and fill in the values below.
# Never commit `.env.local` — it is gitignored for a reason.

# =============================================================================
# Tool architecture (reference)
# =============================================================================
#
# - Browser-side tools (Image Compressor, Image Enlarger, etc.): no API keys —
#   processing stays in the visitor’s browser.
# - Gemini tools (e.g. Image to Prompt): server-side; requires GEMINI_API_KEY.
# - Bytez tools (lighter AI — AI Caption Generator, etc.): server-side;
#   requires BYTEZ_API_KEY. See `src/config/tool-registry.ts` and `src/lib/ai/`.
#
# =============================================================================
# Public site
# =============================================================================

# Canonical URL for metadata, sitemap, and Open Graph base resolution.
# Defaults to https://aibuddy.design if unset.
NEXT_PUBLIC_SITE_URL=https://aibuddy.design

# Full WhatsApp chat URL, e.g. https://wa.me/+447849399437 — must be http(s).
NEXT_PUBLIC_WHATSAPP_URL=

# =============================================================================
# Gemini (premium / heavy AI — Image to Prompt, future vision tools)
# =============================================================================
# Used only in server-side API routes. Never expose to the client.

# Google AI Studio API key — required for POST /api/tools/image-to-prompt
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: pin a specific Gemini model. Defaults to gemini-2.5-flash.
# GEMINI_MODEL=gemini-2.5-flash

# =============================================================================
# Bytez (unified model API — AI Caption Generator, future text tools)
# =============================================================================
# Docs: https://docs.bytez.com/http-reference/model/run
# Server-only. Never expose BYTEZ_* to the client (no NEXT_PUBLIC_*).
#
# Required:
#   BYTEZ_API_KEY — from https://bytez.com/api (Dashboard).
#
# Optional:
#   BYTEZ_API_BASE_URL — production default is https://api.bytez.com (OpenAPI
#     “Production server”). Override only if Bytez gives you a different API host.
#   BYTEZ_MODEL — model id for the URL path `/models/v2/{modelId}` (e.g. org/model).
#     Defaults in code to Qwen/Qwen3-4B (Bytez chat “Get started”; within free-tier
#     7B cap). Set explicitly to pin a version.
#
# Auth: send the key as the raw `Authorization` header value (per OpenAPI
# apiKeyAuth — same as official curl; not `Bearer …`).
#
# BYTEZ_API_KEY=
# BYTEZ_API_BASE_URL=https://api.bytez.com
# BYTEZ_MODEL=Qwen/Qwen3-4B

# =============================================================================
# Supabase auth (required for sign-in + credits)
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# =============================================================================
# Supabase / Prisma (database — credits + usage logs)
# =============================================================================
# Prisma 7 reads DATABASE_URL and DIRECT_URL from env via prisma.config.ts.
# DATABASE_URL — pooled (e.g. port 6543), runtime on serverless.
# DIRECT_URL — direct 5432 for migrations from your machine.
# Special characters in the password MUST be URL-encoded.

# DATABASE_URL=postgresql://...pooler...:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://...pooler...:5432/postgres

# =============================================================================
# Freemium / usage (optional)
# =============================================================================
# Default monthly AI cap for Pro plan profiles (large default ≈ unlimited in practice).
# PRO_AI_MONTHLY_QUOTA=50000

# =============================================================================
# Production diagnostics (optional)
# =============================================================================

# DEBUG_TOKEN=
