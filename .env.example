# Copy this file to `.env.local` and fill in the values below.
# Never commit `.env.local` — it is gitignored for a reason.

# =============================================================================
# Public site
# =============================================================================

# Full WhatsApp chat link, e.g. https://wa.me/15551234567 (https required).
VITE_WHATSAPP_URL=

# =============================================================================
# NVIDIA AI (server-side — used by Vercel Edge Functions / API routes)
# =============================================================================
# These are used by the /api/ai/* serverless functions and are NEVER exposed
# to the client bundle.

# NVIDIA NIM / NGC API key — https://build.nvidia.com
NVIDIA_API_KEY=

# Optional: override the base URL (default: https://integrate.api.nvidia.com/v1)
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
