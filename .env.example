# Copy this file to .env.local and fill in the values below.
# Never commit .env.local — it is gitignored for a reason.

# --- Public site URL (optional) ---
# Canonical URL for metadata, sitemap, and Open Graph base resolution.
# Defaults to https://aibuddy.design if unset.
NEXT_PUBLIC_SITE_URL=https://aibuddy.design

# --- WhatsApp CTA (optional) ---
# Full chat URL, e.g. https://wa.me/+447849399437 — must be http(s).
# When unset, primary CTAs fall back to /contact and mailto email.
NEXT_PUBLIC_WHATSAPP_URL=

# --- Gemini (required for /tools/image-to-prompt) ---
# Google AI Studio API key used server-side by the Image-to-Prompt tool.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: pin a specific Gemini model. Defaults to gemini-2.5-flash.
# GEMINI_MODEL=gemini-2.5-flash

# --- Supabase auth (required for sign-in + credits) ---
# Found in Supabase dashboard → Project Settings → API.
# The anon key is safe to expose to the browser; the service role key must NOT
# be added here — it is not used by the app.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase / Prisma (database, required for credits + usage logs) ---
# Prisma 7 reads DATABASE_URL and DIRECT_URL from env via prisma.config.ts.
# DATABASE_URL — pooled connection, used at runtime by the app (via pgBouncer).
# DIRECT_URL   — direct 5432 connection, used by `prisma migrate` / `db push`.
# If your password contains special characters, URL-encode them (e.g. `@` → %40).
# DATABASE_URL=postgresql://...pooler...:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://...pooler...:5432/postgres
